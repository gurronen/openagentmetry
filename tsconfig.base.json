{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "paths": {
      "@openagentmetry/agent-semantic-contracts": [
        "./packages/agent-semantic-contracts/src/index.ts"
      ],
      "@openagentmetry/opencode-agentmetry": [
        "./packages/opencode-agentmetry/src/index.ts"
      ]
    },
    "strict": true,
    "noEmit": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "forceConsistentCasingInFileNames": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": true,
  },
}
