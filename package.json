{
  "name": "openagentmetry",
  "private": true,
  "version": "0.1.1",
  "license": "Apache-2.0",
  "packageManager": "bun@1.3.10",
  "workspaces": {
    "packages": [
      "packages/*"
    ],
    "catalog": {
      "@typescript/native-preview": "^7.0.0-dev.20260320",
      "@opentelemetry/api": "^1.9.0",
      "@opentelemetry/resources": "^1.24.0",
      "@opentelemetry/sdk-trace-base": "^1.24.0",
      "@opentelemetry/sdk-trace-node": "^1.24.0",
      "@opentelemetry/semantic-conventions": "^1.24.0",
      "lefthook": "^1.7.18",
      "oxfmt": "^0.6.0",
      "oxlint": "^0.18.0",
      "oxlint-tsgolint": "^0.1.0"
    }
  },
  "scripts": {
    "build": "bun -w run build",
    "clean": "bun -w run clean",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "lint": "oxlint",
    "lint:fix": "oxlint --fix",
    "prepare": "lefthook install",
    "test": "bun test",
    "typecheck": "bun -w run typecheck"
  },
  "devDependencies": {
    "@typescript/native-preview": "catalog:",
    "lefthook": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:"
  },
  "engines": {
    "node": ">=18"
  }
}
