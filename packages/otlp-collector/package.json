{
  "name": "@openagentmetry/otlp-collector",
  "version": "0.1.2",
  "license": "Apache-2.0",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "openagentmetry-collector": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsgo -p tsconfig.json && bun build src/index.ts --target bun --format esm --outfile dist/index.js && bun build src/index.ts --target bun --format cjs --outfile dist/index.cjs && bun build src/cli.ts --target bun --format esm --outfile dist/cli.js",
    "clean": "rm -rf dist",
    "test": "bun test",
    "typecheck": "tsgo -p tsconfig.json"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.5",
    "protobufjs": "^7.5.4"
  },
  "devDependencies": {
    "@types/bun": "^1.3.1",
    "@types/node": "catalog:",
    "drizzle-kit": "^0.31.6"
  }
}
